# =============================================================================
# ARD / Tagesschau MCP Server — Environment Configuration
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# .env is git-ignored — never commit secrets.
# =============================================================================

# ── Transport ─────────────────────────────────────────────────────────────────
# stdio  = local Claude Desktop / CLI (default)
# sse    = Server-Sent Events for remote / Docker deployments
TRANSPORT=stdio

# ── Network (only relevant when TRANSPORT=sse) ────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
