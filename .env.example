# =============================================================================
# ARD / Tagesschau MCP Server — Environment Configuration
#
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# .env is git-ignored — never commit secrets.
# =============================================================================

# ── Transport ─────────────────────────────────────────────────────────────────
# stdio           = local Claude Desktop / CLI (default)
# streamable_http = Streamable HTTP for remote / Docker deployments (endpoint: /mcp)
TRANSPORT=stdio

# ── Network (only relevant when TRANSPORT=streamable_http) ───────────────────
HOST=127.0.0.1
PORT=8000

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
